            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"transaction_amount\": {{ $('PREPARE_FIELDS').item.json.amount }},\n  \"date_of_expiration\": \"{{ $('PREPARE_FIELDS').first().json.date_of_expiration }}\",\n  \"payment_method_id\": \"pix\",\n  \"description\": \"Compra de lumes\",\n  \"external_reference\": \"{{ $('PREPARE_FIELDS').item.json.external_reference }}\",\n\"payer\": {\n    \"entity_type\": \"individual\",\n    \"type\": \"customer\",\n    \"email\": \"{{ $('PREPARE_FIELDS').first().json.email }}\"\n}\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
