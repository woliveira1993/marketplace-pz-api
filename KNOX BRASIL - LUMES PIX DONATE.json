        "respondWith": "json",
        "responseBody": "={\n  \"pixCopiaECola\": \"{{ $('RESPONSE_MP').item.json.pixCopiaECola }}\",\n  \"transactionId\": \"{{ $json.transaction_id }}\",\n  \"qrCodeBase64\": \"{{ $('RESPONSE_MP').item.json.qrCodeBase64 }}\",\n  \"expirationDate\": \"{{ $('RESPONSE_MP').item.json.expirationDate }}\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
