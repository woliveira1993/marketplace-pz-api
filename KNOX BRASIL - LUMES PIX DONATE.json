      "id": "c48ba903-4586-4ead-babc-cf8ffb1b9f5f",
      "name": "CRIAR COBRANCA"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $json.body || $json;\nconst username = body.username;\nconst email = body.email;\nconst lumes = parseFloat(body.lumes || 0);\n\n\nif (!username || !email || lumes <= 0) {\n  return {\n    valid: false,\n    error: \"invalid_fields\"\n  };\n}\n\nconst amount = parseFloat((lumes * 0.02).toFixed(2));\n\nreturn {\n  valid: true,\n  username,\n  email,\n  lumes,\n  amount\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -592,
        -80
      ],
      "id": "426f768f-c94a-45ff-988c-a834309317ab",
      "name": "FIELDS"
    },
    {
      "parameters": {
        "jsCode": "try {\n  const randomNum = Math.floor(Math.random() * 999999999);\n  \nconst agora = new Date();\nconst offsetBrasilia = -3;\nconst dataBrasilia = new Date(agora.getTime() + (offsetBrasilia * 60 * 60 * 1000));\n\n\nconst expiracao = new Date(dataBrasilia.getTime() + 30 * 60 * 1000);\n\n\nconst pad = (n) => n.toString().padStart(2, '0');\n\nconst yyyy = expiracao.getUTCFullYear();\nconst mm = pad(expiracao.getUTCMonth() + 1);\nconst dd = pad(expiracao.getUTCDate());\nconst hh = pad(expiracao.getUTCHours());\nconst min = pad(expiracao.getUTCMinutes());\nconst ss = pad(expiracao.getUTCSeconds());\n\nconst date_of_expiration = `${yyyy}-${mm}-${dd}T${hh}:${min}:${ss}.000-03:00`;\n\n  return {\n    idempotencyId: `${$input.first().json.email}-${randomNum}`,\n    external_reference: `${$input.first().json.username}-${randomNum}`,\n    email: $input.first().json.email,\n    username: $input.first().json.username,\n    amount: $input.first().json.amount,\n    lumes: $input.first().json.lumes,\n    date_of_expiration\n  };\n} catch (e) {\n  return { error: \"Execute os nodes anteriores primeiro!\" };\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -192,
        128
      ],
      "id": "dd3b4fc6-ea36-4d28-bc77-37e6b53ae4a8",
      "name": "PREPARE_FIELDS"
