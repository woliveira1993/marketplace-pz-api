# Server
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:8080

# Database
DATABASE_URL=postgresql://zomboid_user:password@localhost:5432/marketplace_pz

# JWT
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Encryption key for MP client_secret and RCON password at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-this-to-64-hex-chars
